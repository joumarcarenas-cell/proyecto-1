#include "raylib.h"
#include <vector>
#include <algorithm>
#include <cmath>

const int MAP_WIDTH = 60;
const int MAP_HEIGHT = 60;

enum TileType { SUELO, PARED };
struct Tile { TileType tipo; Color color; int alturaPixels; };

struct Projectile {
    Vector2 pos;
    Vector2 startPos;
    Vector2 targetPos;
    float timer;
    float travelTime;
    float aoeRadius;
    int baseDamage;
    bool alive;
    Vector2 vel;
    float hitboxRadius;
};

struct NPC {
    Vector2 pos;
    int hp;
    int hpMax;
    bool alive;
    float flashTimer; // Para efecto visual de daño
    float hitboxRadius;
};

struct EntidadDibujable {
    Vector2 posPantalla;
    float profundidad;
    int tipo; // 0:Suelo, 1:Jugador, 2:Techo, 3:Selector, 4:Proyectil, 5:NPC
    Color color;
    int alturaPared;
    float healthBarPct; // Para dibujar la vida
};

// --- FUNCIONES DE CONVERSIÓN ---
static Vector2 GetIso(Vector2 mapPos) {
    return { (mapPos.x - mapPos.y) * 32.0f, (mapPos.x + mapPos.y) * 16.0f };
}

static Vector2 GetMouseMapPos(Vector2 mousePos, Vector2 cameraPos, int anchoP, int altoP) {
    float relX = mousePos.x - (anchoP / 2.0f) + cameraPos.x;
    float relY = mousePos.y - (altoP / 2.0f) + cameraPos.y;
    return { (relX / 64.0f) + (relY / 32.0f), (relY / 32.0f) - (relX / 64.0f) };
}

int main() {
    const int anchoP = 1280;
    const int altoP = 720;
    InitWindow(anchoP, altoP, "Motor Isométrico - Interacción Corregida");
    SetTargetFPS(60);

    // Inicialización de Mapa
    std::vector<Tile> mapa(MAP_WIDTH * MAP_HEIGHT);
    for (int i = 0; i < MAP_WIDTH * MAP_HEIGHT; i++) mapa[i] = { SUELO, LIGHTGRAY, 0 };

    // Entidades
    Vector2 playerPos = { 30.0f, 30.0f };
    std::vector<NPC> npcs;
    npcs.push_back({ {33.0f, 33.0f}, 100, 100, true, 0.0f }); // El Dummy

    std::vector<Projectile> projectiles;
    Vector2 cameraPos = GetIso(playerPos);

    while (!WindowShouldClose()) {
        float dt = GetFrameTime();

        // 1. MOVIMIENTO DEL JUGADOR (Flechas o WASD)
        Vector2 mov = { 0 };
        if (IsKeyDown(KEY_RIGHT) || IsKeyDown(KEY_D)) mov.x += 1;
        if (IsKeyDown(KEY_LEFT) || IsKeyDown(KEY_A)) mov.x -= 1;
        if (IsKeyDown(KEY_DOWN) || IsKeyDown(KEY_S)) mov.y += 1;
        if (IsKeyDown(KEY_UP) || IsKeyDown(KEY_W)) mov.y -= 1;

        if (mov.x != 0 || mov.y != 0) {
            float mag = sqrt(mov.x * mov.x + mov.y * mov.y);
            playerPos.x += (mov.x / mag) * 5.0f * dt;
            playerPos.y += (mov.y / mag) * 5.0f * dt;
        }

        // 2. DISPARO
        Vector2 mPos = GetMouseMapPos(GetMousePosition(), cameraPos, anchoP, altoP);
        if (IsMouseButtonPressed(MOUSE_LEFT_BUTTON)) {
            projectiles.push_back({ playerPos, playerPos, mPos, 0.4f, 0.4f, 1.5f, 35, true });
        }

        // 3. ACTUALIZACIÓN PROYECTILES E INTERACCIÓN
        for (auto& pr : projectiles) {
            if (!pr.alive) continue;
            pr.timer -= dt;
            float t = 1.0f - (pr.timer / pr.travelTime);
            pr.pos = { pr.startPos.x + (pr.targetPos.x - pr.startPos.x) * t,
                       pr.startPos.y + (pr.targetPos.y - pr.startPos.y) * t };

            if (pr.timer <= 0) {
                pr.alive = false;
                // Explosión: Detectar NPCs cerca del punto de impacto
                for (auto& n : npcs) {
                    if (!n.alive) continue;
                    float dist = sqrtf(pow(n.pos.x - pr.targetPos.x, 2) + pow(n.pos.y - pr.targetPos.y, 2));
                    if (dist < pr.aoeRadius) {
                        n.hp -= pr.baseDamage;
                        n.flashTimer = 0.1f; // Efecto de "golpe"
                        if (n.hp <= 0) n.alive = false;
                    }
                }
            }
        }
        projectiles.erase(std::remove_if(projectiles.begin(), projectiles.end(), [](const Projectile& p) { return !p.alive; }), projectiles.end());

        // Actualizar efectos de los NPCs
        for (auto& n : npcs) if (n.flashTimer > 0) n.flashTimer -= dt;

        // 4. CÁMARA
        Vector2 targetCam = GetIso(playerPos);
        cameraPos.x += (targetCam.x - cameraPos.x) * 0.1f;
        cameraPos.y += (targetCam.y - cameraPos.y) * 0.1f;

        // 5. Z-SORTING (Llenar lista de dibujo)
        std::vector<EntidadDibujable> lista;
        int startX = (int)playerPos.x - 15, endX = (int)playerPos.x + 15;
        int startY = (int)playerPos.y - 15, endY = (int)playerPos.y + 15;

        for (int y = std::max(0, startY); y < std::min(MAP_HEIGHT, endY); y++) {
            for (int x = std::max(0, startX); x < std::min(MAP_WIDTH, endX); x++) {
                Vector2 sPos = { (float)(x - y) * 32.0f - cameraPos.x + (anchoP / 2),
                                 (float)(x + y) * 16.0f - cameraPos.y + (altoP / 2) };
                lista.push_back({ sPos, (float)(x + y), 0, LIGHTGRAY, 0, 0 });
            }
        }

        // Jugador
        lista.push_back({ {GetIso(playerPos).x - cameraPos.x + (anchoP / 2), GetIso(playerPos).y - cameraPos.y + (altoP / 2)},
                          playerPos.x + playerPos.y, 1, BLUE, 0, 0 });

        // NPCs
        for (auto& n : npcs) {
            if (!n.alive) continue;
            Vector2 nS = { GetIso(n.pos).x - cameraPos.x + (anchoP / 2), GetIso(n.pos).y - cameraPos.y + (altoP / 2) };
            lista.push_back({ nS, n.pos.x + n.pos.y, 5, (n.flashTimer > 0 ? WHITE : RED), 0, (float)n.hp / n.hpMax });
        }

        // Proyectiles
        for (auto& pr : projectiles) {
            Vector2 pS = { GetIso(pr.pos).x - cameraPos.x + (anchoP / 2), GetIso(pr.pos).y - cameraPos.y + (altoP / 2) };
            lista.push_back({ pS, pr.pos.x + pr.pos.y, 4, ORANGE, 0, 0 });
        }

        std::sort(lista.begin(), lista.end(), [](const EntidadDibujable& a, const EntidadDibujable& b) {
            return a.profundidad < b.profundidad;
            });

        // 6. RENDERIZADO
        BeginDrawing();
        ClearBackground({ 25, 25, 30, 255 });

        for (auto& it : lista) {
            if (it.tipo == 0) DrawPoly(it.posPantalla, 4, 32.5f, 0.0f, it.color);
            else if (it.tipo == 1) { // Jugador
                DrawCircleV(it.posPantalla, 15, it.color);
                DrawCircleLines(it.posPantalla.x, it.posPantalla.y, 15, WHITE);
            }
            else if (it.tipo == 4) DrawCircleV(it.posPantalla, 6, it.color);
            else if (it.tipo == 5) { // NPC
                DrawCircleV(it.posPantalla, 14, it.color);
                // Barra de vida
                DrawRectangle(it.posPantalla.x - 15, it.posPantalla.y - 25, 30, 4, BLACK);
                DrawRectangle(it.posPantalla.x - 15, it.posPantalla.y - 25, 30 * it.healthBarPct, 4, GREEN);
            }
        }

        DrawText("WASD/Flechas: Mover | Click Izquierdo: Disparar", 10, 10, 20, RAYWHITE);
        EndDrawing();
    }
    CloseWindow();
    return 0;
}