#ifndef PLAYER_H
#define PLAYER_H

#include "Entity.h"
#include <vector>
#include <cmath>

// Declaración necesaria para que el compilador sepa qué es un Tile
struct Tile;

class Player : public Entity {
public:
    float dashCD = 0.0f;
    float dashTimer = 0.0f;

    Player(Vector2 startPos) {
        pos = startPos;
        stats = { 100.0f, 100.0f, 50.0f, 50.0f, 1, 0.10f }; // hp, hpMax, stamina, staminaMax, level, speed
        color = GREEN;
    }

    // Sobrecarga de la función con 4 argumentos como pide Entity.h
    void Update(float dt, const std::vector<struct Tile>& mapa, int MAP_W, int MAP_H) override {
        // Lógica de timers
        if (dashCD > 0) dashCD -= dt;
        if (dashTimer > 0) dashTimer -= dt;

        // Movimiento básico
        Vector2 input = { 0, 0 };
        if (IsKeyDown(KEY_RIGHT)) input.x += 1;
        if (IsKeyDown(KEY_LEFT))  input.x -= 1;
        if (IsKeyDown(KEY_UP))    input.y -= 1;
        if (IsKeyDown(KEY_DOWN))  input.y += 1;

        // Activar Dash
        if (IsKeyPressed(KEY_LEFT_SHIFT) && dashCD <= 0 && (input.x != 0 || input.y != 0)) {
            dashTimer = 0.18f;
            dashCD = 0.90f;
        }

        if (input.x != 0 || input.y != 0) {
            // Dirección isométrica
            Vector2 dirM = { (16.0f * input.x + 32.0f * input.y) / 1024.0f,
                             (-16.0f * input.x + 32.0f * input.y) / 1024.0f };

            float mag = sqrtf(dirM.x * dirM.x + dirM.y * dirM.y);
            float currentSpeed = (dashTimer > 0) ? stats.speed * 4.5f : stats.speed;

            // Aquí podrías añadir colisiones usando el parámetro 'mapa' recibido
            pos.x += (dirM.x / mag) * currentSpeed;
            pos.y += (dirM.y / mag) * currentSpeed;
        }
    }

    // Implementación obligatoria de la segunda sobrecarga
    void Update(float dt) override {
        // Se puede dejar vacío o llamar a la otra versión con datos nulos
    }

    void Draw(Vector2 cameraPos, int anchoP, int altoP) override {
        Vector2 iso = GetIsoPos();
        Vector2 screen = { iso.x - cameraPos.x + (anchoP / 2), iso.y - cameraPos.y + (altoP / 2) };

        Color pCol = (dashTimer > 0) ? YELLOW : (dashCD <= 0 ? color : MAROON);

        DrawCircleV(screen, 15, pCol);
        DrawCircleLines((int)screen.x, (int)screen.y, 15, WHITE);
    }
};

#endif