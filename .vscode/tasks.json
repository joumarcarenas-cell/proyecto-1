{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build_game",
            "type": "shell",
            "command": "g++",
            "args": [
                "-g",
                "-O0",
                "-Wall",
                "${workspaceFolder}/*.cpp",
                "-o",
                "${workspaceFolder}/build/Debug/outDebug.exe",
                "-lraylib",
                "-lgdi32",
                "-lwinmm"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        }
    ]
}
